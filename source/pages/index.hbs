<div id="home" class="wrapper bio">
	<div class="container">
		<article>
			<header>
				<h1>{{ site.title }}</h1>
			</header>
			
			<section>
				{{#markdown}}{{> 01_bio }}{{/markdown}}
			</section>
			
			<footer>
				<ul>
					{{#each site.footer_links}}
					<li>
						<a href="{{url}}" title="{{description}}">
							<img class="iconic" data-src="/assets/images/{{image}}" alt="{{title}}">
						</a>
					</li>
					{{/each}}
				</ul>
			</footer>
		</article>
	</div>
</div>

<div id="projects" class="wrapper projects">
	<div class="container">
		<article>
			<header>
				<h1>GitHub Projects</h1>
			</header>
			
			<section id="js-github-projects"></section>
			{{> 02_projects }}
		</article>
	</div>
</div>
